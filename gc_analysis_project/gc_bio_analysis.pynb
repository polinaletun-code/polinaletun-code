   "source": [
    "\"\"\"\n",
    "GC-состав анализатор\n",
    "Программа считает GC-состав для списка ДНК-последовательностей и сохраняет результаты\n",
    "\"\"\"\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Список ДНК-последовательностей\n",
    "dna_list = [\n",
    "    \"ATGCGTACGTAGCTAGCT\",  # Ген 1\n",
    "    \"AAATTTCCCGGG\",        # Ген 2\n",
    "    \"GCCGCCGCCGCGCGC\",     # Ген 3\n",
    "    \"ATATATATATAT\",        # Ген 4\n",
    "    \"CGCGCGCGCGCG\",        # Ген 5\n",
    "]\n",
    "# Пустые списки для результатов\n",
    "names = []\n",
    "gc_percents = []\n",
    "print(\"=\" * 40)\n",
    "print(\"🧬 АНАЛИЗ GC-СОСТАВА ДНК\")\n",
    "print(\"=\" * 40)\n",
    "\n",
    "# Считаем GC для каждой ДНК\n",
    "for i, dna in enumerate(dna_list, 1):\n",
    "    length = len(dna)\n",
    "    g_count = dna.count(\"G\")\n",
    "    c_count = dna.count(\"C\")\n",
    "    gc_total = g_count + c_count\n",
    "    gc_percent = (gc_total / length) * 100\n",
    "    name = f\"Ген {i}\"\n",
    "    names.append(name)\n",
    "    gc_percents.append(gc_percent)\n",
    "    \n",
    "    # Вывод в консоль\n",
    "    print(f\"{name}:\")\n",
    "    print(f\"  Длина: {length}\")\n",
    "    print(f\"  G+C: {gc_total}\")\n",
    "    print(f\"  GC-%: {round(gc_percent, 1)}%\")\n",
    "    print(\"-\" * 30)\n",
    "\n",
    "# Сохраняем результаты в файл\n",
    "with open(\"results.txt\", \"w\", encoding=\"utf-8\") as f:\n",
    "    f.write(\"Результаты анализа GC-состава\\n\")\n",
    "    f.write(\"=\" * 30 + \"\\n\")\n",
    "    for name, gc in zip(names, gc_percents):\n",
    "        f.write(f\"{name}: {round(gc, 1)}%\\n\")\n",
    "print(\"\\n✅ Результаты сохранены в файл results.txt\")\n",
    "\n",
    "# Строим график\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.bar(names, gc_percents, color=\"skyblue\", edgecolor=\"black\")\n",
    "plt.axhline(y=50, color=\"red\", linestyle=\"--\", label=\"50% (порог)\")\n",
    "plt.xlabel(\"Гены\")\n",
    "plt.ylabel(\"GC-состав (%)\")\n",
    "plt.title(\"GC-состав исследуемых генов\")\n",
    "plt.ylim(0, 100)\n",
    "plt.legend()\n",
    "plt.grid(axis=\"y\", linestyle=\"--\", alpha=0.7)\n",
    "\n",
    "# Сохраняем график\n",
    "plt.savefig(\"gc_plot.png\", dpi=300)\n",
    "print(\"✅ График сохранён как gc_plot.png\")\n",
    "\n",
    "# Показываем график\n",
    "plt.show()"
   ]
  },
